---
// Imported from frontmatter (not CSS @import) so Vite bundles the
// woff2 files. CSS @import works in dev but drops font assets at build.
import "@fontsource/eb-garamond/400.css";
import "@fontsource/eb-garamond/400-italic.css";
import "@fontsource/eb-garamond/600.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const fullTitle = title
  ? `${title} — The Yellow Legal Pad`
  : "The Yellow Legal Pad — Financial coaching for life's biggest transitions";

const meta =
  description ??
  "The Yellow Legal Pad — financial coaching with Stacey, for people navigating retirement, divorce, widowhood, late starts, caregiving, and other transitions. Remote sessions, plain language, no products.";

// Active-link detection. Match by pathname; trailing-slash tolerant.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return path === normalized;
};

// Canonical + og:url only render when astro.config has `site` set,
// otherwise we'd ship localhost URLs to production.
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={meta} />
    <meta name="theme-color" content="#f6f1e6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#161616" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />
    {/* Pre-paint script: reads user settings from localStorage and
        applies data-* attributes to <html> before first paint, so
        the page never flashes the wrong theme. Re-runs after every
        Astro view transition swap. */}
    <script is:inline>
      (function () {
        function apply() {
          try {
            var s = JSON.parse(localStorage.getItem("ylp:settings") || "{}");
            var root = document.documentElement;
            if (s.theme === "light" || s.theme === "dark") {
              root.setAttribute("data-theme", s.theme);
            } else {
              root.removeAttribute("data-theme");
            }
            if (s.fontSize === "larger") {
              root.setAttribute("data-font-size", "larger");
            } else {
              root.removeAttribute("data-font-size");
            }
            if (s.motion === "off") {
              root.setAttribute("data-motion", "off");
            } else {
              root.removeAttribute("data-motion");
            }
          } catch (e) {}
        }
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>
    {/* Gentle background parallax. Library tiles inside the fixed
        depth-wash pseudo; this script translates the library's
        background-position-y at ~15% of scroll speed so the wall
        slides down slightly as the visitor reads downward. The
        paper sheet and content scroll normally at 1.0x; only the
        wall is slowed. */}
    <script is:inline>
      (function () {
        var ticking = false;
        var rate = 0.15;
        function motionOff() {
          if (
            document.documentElement.getAttribute("data-motion") === "off"
          ) {
            return true;
          }
          if (
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            return true;
          }
          return false;
        }
        function update() {
          if (motionOff()) {
            document.documentElement.style.setProperty(
              "--bg-parallax-y",
              "0px"
            );
            ticking = false;
            return;
          }
          var y = window.scrollY * rate;
          document.documentElement.style.setProperty(
            "--bg-parallax-y",
            y + "px"
          );
          ticking = false;
        }
        function onScroll() {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        document.addEventListener("astro:after-swap", function () {
          window.scrollTo(0, 0);
          update();
          /* Move focus to the new <main> so screen readers announce
             the freshly-swapped page. ClientRouter leaves focus on
             the link the user clicked, which is now sitting in the
             new page's header — confusing for AT users. main has
             tabindex="-1" and main:focus { outline: none } so this
             is invisible to mouse/sighted users. */
          var main = document.getElementById("main-content");
          if (main) {
            try {
              main.focus({ preventScroll: true });
            } catch (e) {
              main.focus();
            }
          }
        });
        update();
      })();
    </script>
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {/* Open Graph + Twitter — share unfurls. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Yellow Legal Pad" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content="/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Yellow Legal Pad — financial coaching for life's biggest transitions" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={meta} />
    <meta name="twitter:image" content="/og.png" />
    <ClientRouter />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <div class="site-paper" transition:name="paper">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-header__brand" aria-label="The Yellow Legal Pad — home">
            The Yellow Legal Pad
          </a>
          <nav class="site-header__nav" aria-label="Primary">
            <a href="/about" class:list={["site-header__link", { "is-active": isActive("/about") }]} aria-current={isActive("/about") ? "page" : undefined}>About</a>
            <a href="/services" class:list={["site-header__link", { "is-active": isActive("/services") }]} aria-current={isActive("/services") ? "page" : undefined}>Services</a>
            <a href="/resources" class:list={["site-header__link", { "is-active": isActive("/resources") }]} aria-current={isActive("/resources") ? "page" : undefined}>Resources</a>
            <a href="/contact" class:list={["site-header__link", { "is-active": isActive("/contact") }]} aria-current={isActive("/contact") ? "page" : undefined}>Contact</a>
          </nav>
        </div>
      </header>

      <main id="main-content" tabindex="-1">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <nav class="site-footer__nav" aria-label="Footer">
            <a href="/about" class="site-footer__link">About</a>
            <a href="/services" class="site-footer__link">Services</a>
            <a href="/resources" class="site-footer__link">Resources</a>
            <a href="/contact" class="site-footer__link">Contact</a>
            <a href="/settings" class="site-footer__link">Settings</a>
          </nav>
          <p class="caption site-footer__disclaimer">
            The Yellow Legal Pad provides financial coaching and education
            only. This is not financial advice, investment advice, legal
            advice, or tax advice. Consult a licensed professional for
            advice specific to your situation.
          </p>
          <p class="caption site-footer__note">
            The Yellow Legal Pad &middot; Stacey &middot; Vero Beach, Florida
          </p>
        </div>
      </footer>
    </div>

  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* Hidden off-screen until keyboard focus reveals it. position:
     fixed so the skip link stays anchored to the viewport even if
     an ancestor creates a new containing block (filters, transforms,
     view-transition pseudos), which previously caused it to render
     visibly on desktop. */
  .skip-link {
    position: fixed;
    top: -3rem;
    left: 1rem;
    padding: 0.5rem 0.875rem;
    background-color: var(--c-paper);
    color: var(--c-ink);
    font-size: 0.875rem;
    text-decoration: none;
    border: 1px solid rgba(var(--c-rule-rgb), 0.4);
    border-radius: 2px;
    z-index: 1000;
  }

  .skip-link:focus {
    top: 0.75rem;
    outline: 2px solid var(--c-ink);
    outline-offset: 2px;
  }

  /* Suppress focus ring on <main> when the skip link sends focus there. */
  main:focus {
    outline: none;
  }

  .site-header {
    padding-top: 1rem;
    padding-bottom: 0.875rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    border-bottom: 1px solid rgba(var(--c-rule-rgb), var(--c-rule-alpha));
  }

  @media (min-width: 40rem) {
    .site-header {
      padding-top: 1.5rem;
      padding-bottom: 1rem;
      padding-left: 1.75rem;
      padding-right: 1.75rem;
    }
  }

  .site-header__inner {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }

  .site-header__brand {
    font-family: theme("fontFamily.serif");
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .site-header__brand:hover {
    text-decoration: underline;
    text-decoration-color: var(--c-gold);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .site-header__link {
    font-size: 0.95rem;
    color: var(--c-ink-soft);
    text-decoration: none;
  }

  .site-header__link:hover {
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-gold);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-header__link.is-active {
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-gold);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer {
    padding-top: 1.5rem;
    padding-bottom: 1.75rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    border-top: 1px solid rgba(var(--c-rule-rgb), var(--c-rule-alpha));
    margin-top: 1rem;
  }

  @media (min-width: 40rem) {
    .site-footer {
      padding-top: 2rem;
      padding-bottom: 2.25rem;
      padding-left: 1.75rem;
      padding-right: 1.75rem;
      margin-top: 1.5rem;
    }
  }

  .site-footer__inner {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .site-footer__link {
    font-size: 0.9375rem;
    color: var(--c-ink-soft);
    text-decoration: none;
  }

  .site-footer__link:hover {
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-gold);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer__note {
    color: var(--c-ink-muted);
    margin-bottom: 0;
    max-width: none;
  }

  .site-footer__disclaimer {
    color: var(--c-ink-muted);
    font-style: normal;
    font-size: 0.8125rem;
    line-height: 1.55;
    max-width: 44rem;
    margin-bottom: 0;
  }
</style>
