---
// Imported from frontmatter (not CSS @import) so Vite bundles the
// woff2 files. CSS @import works in dev but drops font assets at build.
import "@fontsource/eb-garamond/400.css";
import "@fontsource/eb-garamond/400-italic.css";
import "@fontsource/eb-garamond/600.css";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const fullTitle = title
  ? `${title} — The Yellow Legal Pad`
  : "The Yellow Legal Pad — Financial coaching for life's biggest transitions";

const meta =
  description ??
  "The Yellow Legal Pad — financial coaching with Stacey, for people navigating retirement, divorce, widowhood, late starts, caregiving, and other transitions. Remote sessions, plain language, no products.";

// Active-link detection. Match by pathname; trailing-slash tolerant.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return path === normalized;
};

// Canonical + og:url only render when astro.config has `site` set,
// otherwise we'd ship localhost URLs to production.
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={meta} />
    <meta name="theme-color" content="#f6f1e6" />
    {/* Site is light-only — keeps UA chrome (scrollbar etc.) light
        even when the OS prefers dark. */}
    <meta name="color-scheme" content="light" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {/* Open Graph + Twitter — quiet defaults for shared links */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={meta} />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__brand" aria-label="The Yellow Legal Pad — home">
          The Yellow Legal Pad
        </a>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="/about" class:list={["site-header__link", { "is-active": isActive("/about") }]} aria-current={isActive("/about") ? "page" : undefined}>About</a>
          <a href="/services" class:list={["site-header__link", { "is-active": isActive("/services") }]} aria-current={isActive("/services") ? "page" : undefined}>Services</a>
          <a href="/resources" class:list={["site-header__link", { "is-active": isActive("/resources") }]} aria-current={isActive("/resources") ? "page" : undefined}>Resources</a>
          <a href="/contact" class:list={["site-header__link", { "is-active": isActive("/contact") }]} aria-current={isActive("/contact") ? "page" : undefined}>Contact</a>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <nav class="site-footer__nav" aria-label="Footer">
          <a href="/about" class="site-footer__link">About</a>
          <a href="/services" class="site-footer__link">Services</a>
          <a href="/resources" class="site-footer__link">Resources</a>
          <a href="/contact" class="site-footer__link">Contact</a>
        </nav>
        <p class="caption site-footer__disclaimer">
          The Yellow Legal Pad provides financial coaching and education
          only. This is not financial advice, investment advice, legal
          advice, or tax advice. Consult a licensed professional for
          advice specific to your situation.
        </p>
        <p class="caption site-footer__note">
          The Yellow Legal Pad &middot; Stacey &middot; Vero Beach, Florida
        </p>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* Hidden off-screen until keyboard focus reveals it. */
  .skip-link {
    position: absolute;
    top: -3rem;
    left: 1rem;
    padding: 0.5rem 0.875rem;
    background-color: theme("colors.paper.DEFAULT");
    color: theme("colors.ink.DEFAULT");
    font-size: 0.875rem;
    text-decoration: none;
    border: 1px solid rgba(168, 127, 43, 0.4);
    border-radius: 2px;
    z-index: 10;
  }

  .skip-link:focus {
    top: 0.75rem;
    outline: 2px solid theme("colors.gold.DEFAULT");
    outline-offset: 2px;
  }

  /* Suppress focus ring on <main> when the skip link sends focus there. */
  main:focus {
    outline: none;
  }

  .site-header {
    padding-top: 1.25rem;
    padding-bottom: 0.875rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    border-bottom: 1px solid rgba(168, 127, 43, 0.10);
  }

  @media (min-width: 40rem) {
    .site-header {
      padding-top: 2rem;
      padding-bottom: 1rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  .site-header__inner {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }

  .site-header__brand {
    font-family: theme("fontFamily.serif");
    font-size: 1.1rem;
    font-weight: 600;
    color: theme("colors.ink.DEFAULT");
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .site-header__brand:hover {
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .site-header__link {
    font-size: 0.95rem;
    color: theme("colors.ink.soft");
    text-decoration: none;
  }

  .site-header__link:hover {
    color: theme("colors.ink.DEFAULT");
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-header__link.is-active {
    color: theme("colors.ink.DEFAULT");
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    border-top: 1px solid rgba(168, 127, 43, 0.10);
    margin-top: 3rem;
  }

  @media (min-width: 40rem) {
    .site-footer {
      padding-top: 4rem;
      padding-bottom: 4rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      margin-top: 6rem;
    }
  }

  .site-footer__inner {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .site-footer__link {
    font-size: 0.9375rem;
    color: theme("colors.ink.soft");
    text-decoration: none;
  }

  .site-footer__link:hover {
    color: theme("colors.ink.DEFAULT");
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer__note {
    color: theme("colors.ink.muted");
    margin-bottom: 0;
    max-width: none;
  }

  .site-footer__disclaimer {
    color: theme("colors.ink.muted");
    font-style: normal;
    font-size: 0.8125rem;
    line-height: 1.55;
    max-width: 44rem;
    margin-bottom: 0;
  }
</style>
