---
// BaseLayout — shared shell for every page.
//
// Per relay #37 §1: navigation should feel "quietly adjacent, not
// app-like. No sticky-nav sophistication. No mega menus. No routing
// abstractions. No transition systems. Simple links."
//
// This layout provides:
//   - <head> with meta + global CSS
//   - a quiet header with text-only navigation (NOT sticky)
//   - a <main> slot for page content
//   - a quiet footer with the same links + a small acknowledgement
//
// The header and footer are deliberately small. The page content
// breathes; the chrome doesn't compete.
//
// Single Astro layout. No further abstractions. No <Header> /
// <Footer> components yet — they're 30 lines combined; splitting
// them would add navigation cost without benefit.

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const fullTitle = title
  ? `${title} — Yellow Legal Pad`
  : "Yellow Legal Pad";

const meta =
  description ??
  "Yellow Legal Pad — financial coaching with Stacey. A quiet conversation, without judgment.";

// Active-link detection. Match by pathname; trailing-slash tolerant.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return path === normalized;
};

// Canonical + og:url only render when astro.config.mjs has `site`
// configured. Without it, Astro falls back to http://localhost:4321
// at build time and we'd ship localhost URLs to production. Owner
// sets `site` once Stacey's domain is known; canonical comes back
// automatically on the next build.
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={meta} />
    <meta name="theme-color" content="#f6f1e6" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {/* Open Graph + Twitter — quiet defaults for shared links */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={meta} />
  </head>

  <body>
    <script is:inline>
      document.documentElement.classList.add("js-enabled");
    </script>

    <!-- Skip-to-content link. Invisible until tab focus. Lets
         keyboard and screen-reader users jump past the header
         straight to the page body. -->
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Quiet header. Plain text links. NOT sticky. The header
         is part of the page, not floating over it. The mobile
         layout simply wraps to two lines if needed — no
         hamburger menu. -->
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__brand" aria-label="Yellow Legal Pad — home">
          Yellow Legal Pad
        </a>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="/about" class:list={["site-header__link", { "is-active": isActive("/about") }]}>About</a>
          <a href="/services" class:list={["site-header__link", { "is-active": isActive("/services") }]}>Services</a>
          <a href="/resources" class:list={["site-header__link", { "is-active": isActive("/resources") }]}>Resources</a>
          <a href="/contact" class:list={["site-header__link", { "is-active": isActive("/contact") }]}>Contact</a>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- Quiet footer. Same links offered again — for visitors who
         finish reading and want a next page. Small acknowledgement
         beneath. No social icons, no newsletter signup, no
         "powered by." -->
    <footer class="site-footer">
      <div class="site-footer__inner">
        <nav class="site-footer__nav" aria-label="Footer">
          <a href="/" class="site-footer__link">Home</a>
          <a href="/about" class="site-footer__link">About</a>
          <a href="/services" class="site-footer__link">Services</a>
          <a href="/resources" class="site-footer__link">Resources</a>
          <a href="/contact" class="site-footer__link">Contact</a>
        </nav>
        <p class="caption site-footer__note">
          Yellow Legal Pad &middot; Stacey
        </p>
      </div>
    </footer>

    <!-- Tiny IntersectionObserver — same as before; only motion
         on the page. Section-level fade-in. Inert if reduce-motion
         requested or JS disabled. -->
    <script is:inline>
      (function () {
        if (typeof window === "undefined") return;
        if (typeof IntersectionObserver === "undefined") return;
        var prefersReduced =
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (prefersReduced) return;

        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 }
        );

        document.querySelectorAll(".reveal-on-scroll").forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* Skip-to-content link. Hidden off-screen until it receives
     keyboard focus, at which point it becomes a small, plain link
     in the top-left corner. Visually quiet so it doesn't startle;
     functionally honest for assistive-tech users. */
  .skip-link {
    position: absolute;
    top: -3rem;
    left: 1rem;
    padding: 0.5rem 0.875rem;
    background-color: theme("colors.paper.DEFAULT");
    color: theme("colors.ink.DEFAULT");
    font-family: theme("fontFamily.sans");
    font-size: 0.875rem;
    text-decoration: none;
    border: 1px solid rgba(168, 127, 43, 0.4);
    border-radius: 2px;
    z-index: 10;
  }

  .skip-link:focus {
    top: 0.75rem;
    outline: 2px solid theme("colors.gold.DEFAULT");
    outline-offset: 2px;
  }

  /* Remove the default focus ring on <main> when it receives
     programmatic focus from the skip link — the link's own focus
     state is enough indication, and a ring around the entire
     content area would be visually loud. */
  main:focus {
    outline: none;
  }

  /* Site header — small, calm, document-like. Not floating, not
     sticky. Reads as "the top of the page" not "navigation bar."
     The separator is a soft gold rule rather than a hard divider. */
  .site-header {
    padding-top: 1.25rem;
    padding-bottom: 0.875rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    border-bottom: 1px solid rgba(168, 127, 43, 0.18);
  }

  @media (min-width: 40rem) {
    .site-header {
      padding-top: 2rem;
      padding-bottom: 1rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  .site-header__inner {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }

  .site-header__brand {
    font-family: theme("fontFamily.serif");
    font-size: 1.1rem;
    font-weight: 600;
    color: theme("colors.ink.DEFAULT");
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .site-header__brand:hover {
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .site-header__link {
    font-family: theme("fontFamily.sans");
    font-size: 0.9rem;
    color: theme("colors.ink.soft");
    text-decoration: none;
    letter-spacing: 0;
  }

  .site-header__link:hover {
    color: theme("colors.ink.DEFAULT");
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-header__link.is-active {
    color: theme("colors.ink.DEFAULT");
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  /* Site footer — same links offered again, plus a small
     acknowledgement. Quieter than the header. */
  .site-footer {
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
    border-top: 1px solid rgba(168, 127, 43, 0.18);
    margin-top: 3rem;
  }

  @media (min-width: 40rem) {
    .site-footer {
      padding-top: 4rem;
      padding-bottom: 4rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      margin-top: 6rem;
    }
  }

  .site-footer__inner {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .site-footer__link {
    font-family: theme("fontFamily.sans");
    font-size: 0.875rem;
    color: theme("colors.ink.soft");
    text-decoration: none;
  }

  .site-footer__link:hover {
    color: theme("colors.ink.DEFAULT");
    text-decoration: underline;
    text-decoration-color: theme("colors.gold.DEFAULT");
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .site-footer__note {
    color: theme("colors.ink.muted");
    margin-bottom: 0;
    max-width: none;
  }
</style>
