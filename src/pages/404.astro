---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Not found"
  description="That page isn't here. The home page or contact page may be what you were looking for."
>
  <section class="section" aria-labelledby="not-found-heading">
    <div class="column">
      <h1 id="not-found-heading">That page isn't here.</h1>

      <p>
        Maybe a link went stale, or a typo crept in. No bother.
      </p>

      <p>
        You can <a href="/">return home</a>, look at the
        <a href="/services">services</a>, or
        <a href="/contact">book a Discovery Call</a> &mdash; whichever
        is closer to what you needed.
      </p>
    </div>
  </section>
</BaseLayout>
