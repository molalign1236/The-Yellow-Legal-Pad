---
import BaseLayout from "../layouts/BaseLayout.astro";

// Home page — the welcome mat.
//
// Per Pass 308 §2 / Pass 309 §10 / relay #37 §1: the home page is
// no longer the entire site. The full Story moves to /about; the
// full Philosophy + Process + Packages move to /about and /services.
// Home offers reassurance + a brief hint of what's here + an
// invitation to a Discovery Call.
//
// Real tonal copy below — drawn from relay #33-#37 phrases. NOT
// final Stacey copy; she'll edit. But specifically NOT placeholder
// either. The site should already feel like Stacey speaking.
//
// Three-beat rhythm honored: reassurance → practical → permission.
---

<BaseLayout
  description="Yellow Legal Pad — financial coaching with Stacey. A quiet conversation, without judgment."
>
  <!-- =====================================================
       1. REASSURANCE
       Above-the-fold permission moment.
       ===================================================== -->
  <section class="section" aria-labelledby="welcome-heading">
    <div class="column">
      <h1 id="welcome-heading">
        The welcome mat is out.
      </h1>
      <p>
        If money has felt complicated, embarrassing, or quietly heavy &mdash;
        you're in the right place. There's nothing to know before you arrive.
      </p>
      <p>
        Yellow Legal Pad is a small practice run by Stacey.
        She helps people, couples, and families think about money calmly.
        That's it. No products. No pitches. No judgment.
      </p>
    </div>
  </section>

  <!-- =====================================================
       2. STORY PREVIEW (the Grampy story moves to /about)
       ===================================================== -->
  <section class="section" aria-labelledby="origin-heading">
    <div class="column">
      <h2 id="origin-heading">About the name</h2>
      <p>
        The name comes from Stacey's grandfather &mdash; Grampy &mdash; who would
        sit down with anyone who asked, pull out a yellow legal pad, and walk
        through the math of their life with them. Slowly. Kindly. Until the
        numbers stopped feeling scary.
      </p>
      <p>
        That's the practice. <a href="/about">Read more about Stacey <span aria-hidden="true">&rarr;</span></a>
      </p>
    </div>
  </section>

  <!-- =====================================================
       3. PHILOSOPHY EXCERPT (the central reframe)
       ===================================================== -->
  <section class="section" aria-labelledby="philosophy-heading">
    <div class="column">
      <h2 id="philosophy-heading">A different starting point</h2>
      <p>
        Most financial advice begins by suggesting you've fallen behind. We
        don't agree. The people who come here aren't financially
        unintelligent. They are financially underserved &mdash; by an
        industry that talks past them, charges too much, and assumes they
        should already know.
      </p>
      <p>
        Stacey starts somewhere else: a real conversation, in plain language,
        about your actual life. Whatever's in front of you now is what we
        work with.
      </p>
    </div>
  </section>

  <!-- =====================================================
       4. INVITATION
       Closing. Soft. Conversational. The CTA is a plain
       link, not a button.
       ===================================================== -->
  <section class="section" aria-labelledby="invite-heading">
    <div class="column">
      <h2 id="invite-heading">If you'd like to talk</h2>
      <p>
        A Discovery Call is short, free, and unhurried. Stacey listens, asks
        a few questions, and tells you honestly whether she can help.
        That's it. No pressure to continue.
      </p>
      <p>
        The best time to start was when Grampy was sitting at the kitchen
        table. The second best time is today.
      </p>
      <p style="margin-top: 2.5rem;">
        <a href="/contact">Book a Discovery Call <span aria-hidden="true">&rarr;</span></a>
      </p>
    </div>
  </section>
</BaseLayout>
