---
import BaseLayout from "../layouts/BaseLayout.astro";

// Resources — small library of guides. Titles render as plain text
// until real PDFs land; then wrap each in <a href="/guides/<file>.pdf">.
---

<BaseLayout
  title="Resources"
  description="A small library of guides Stacey has written for people sorting out money calmly."
>
  <section class="section" aria-labelledby="library-heading">
    <div class="column">
      <h1 id="library-heading">A few useful papers</h1>

      <!-- Image slot — pending warm abstract imagery from Stacey
           (legal pad and pen, desk scene, natural textures; no
           stock photos of women). See TODO_STACEY.md § Brand
           imagery. Uncomment alongside the Pass 459 follow-up.
      <figure class="page-image">
        <img src="/images/resources-header.jpg" alt="" />
      </figure>
      -->

      <p>
        Stacey writes things down. These are the ones people ask
        about most. Read what helps; skip what doesn't.
      </p>

      <p><em>&ldquo;Take your time. Read it with a cup of tea, not between meetings.&rdquo;</em></p>

      <p>
        Nothing here is required reading or meant to be worked
        through in order. Use any of them as reference when
        something specific comes up.
      </p>

      <p>
        No email signups, no download forms. Just papers.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="entries-heading">
    <div class="column-wide">
      <h2 id="entries-heading" class="visually-hidden">Guides</h2>

      <article style="margin-bottom: 3rem;">
        <h3>Five Moves That Change Everything</h3>
        <p>
          The five things Stacey returns to most often &mdash; the
          ones that, if you do nothing else, change the shape of the
          years ahead. Short, plain, and roughly in the order they
          tend to matter.
        </p>
        <p class="caption">about 6 pages</p>
      </article>

      <article style="margin-bottom: 3rem;">
        <h3>Where Did It All Go?</h3>
        <p>
          For when the money comes in and somehow leaves before
          you've worked out how. A calm look at where it actually
          goes, without judgement and without a spreadsheet to fill
          in.
        </p>
        <p class="caption">about 5 pages</p>
      </article>

      <article style="margin-bottom: 3rem;">
        <h3>Money as a Family</h3>
        <p>
          For families with kids who haven't yet had The Money
          Conversation, or have had a stilted version of it. A short
          guide on what to say, when to say it, and how to make it
          feel ordinary.
        </p>
        <p class="caption">about 8 pages</p>
      </article>

      <article style="margin-bottom: 3rem;">
        <h3>Money and Your Partner</h3>
        <p>
          For couples who love each other and disagree about money,
          or who haven't figured out yet how to talk about it
          without one person feeling judged. Plain language. No
          worksheets.
        </p>
        <p class="caption">about 6 pages</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="column">
      <p>
        If a paper raised more questions than it answered, that's
        normal. The guides are starting points; some lives need a
        longer conversation. <a href="/contact">Book a Discovery
        Call</a> if that's where you've ended up.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hide visually but keep in the accessibility tree. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
