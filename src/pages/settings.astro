---
import BaseLayout from "../layouts/BaseLayout.astro";

// Settings — color mode, text size, page transitions. Stored in
// localStorage; the pre-paint script in BaseLayout applies them on
// every page load so there's no flash of wrong theme.
---

<BaseLayout
  title="Settings"
  description="Site settings for The Yellow Legal Pad — color mode, text size, and page transitions."
>
  <section class="section" aria-labelledby="settings-heading">
    <div class="column">
      <h1 id="settings-heading">Settings</h1>
      <p>
        These choices are saved in your browser only &mdash; they
        don't leave this device, and nothing is sent to anyone.
      </p>

      <form id="settings-form" class="settings-form" aria-label="Site settings">
        <fieldset>
          <legend>Color mode</legend>
          <label>
            <input type="radio" name="theme" value="system" />
            <span>Match my system</span>
          </label>
          <label>
            <input type="radio" name="theme" value="light" />
            <span>Always light</span>
          </label>
          <label>
            <input type="radio" name="theme" value="dark" />
            <span>Always dark</span>
          </label>
        </fieldset>

        <fieldset>
          <legend>Text size</legend>
          <label>
            <input type="radio" name="fontSize" value="default" />
            <span>Default</span>
          </label>
          <label>
            <input type="radio" name="fontSize" value="larger" />
            <span>Larger</span>
          </label>
        </fieldset>

        <fieldset>
          <legend>Page transitions</legend>
          <label>
            <input type="radio" name="motion" value="system" />
            <span>Match my system</span>
          </label>
          <label>
            <input type="radio" name="motion" value="off" />
            <span>Off</span>
          </label>
        </fieldset>
      </form>

      <p class="caption" style="margin-top: 2rem;">
        Changes apply right away. Your previous choices will be
        remembered the next time you visit.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline data-astro-rerun>
  (function () {
    var KEY = "ylp:settings";
    var form = document.getElementById("settings-form");
    if (!form) return;

    function load() {
      try {
        return JSON.parse(localStorage.getItem(KEY) || "{}");
      } catch (e) {
        return {};
      }
    }
    function save(s) {
      try {
        localStorage.setItem(KEY, JSON.stringify(s));
      } catch (e) {}
    }
    function applyToDOM(s) {
      var root = document.documentElement;
      if (s.theme === "light" || s.theme === "dark") {
        root.setAttribute("data-theme", s.theme);
      } else {
        root.removeAttribute("data-theme");
      }
      if (s.fontSize === "larger") {
        root.setAttribute("data-font-size", "larger");
      } else {
        root.removeAttribute("data-font-size");
      }
      if (s.motion === "off") {
        root.setAttribute("data-motion", "off");
      } else {
        root.removeAttribute("data-motion");
      }
    }
    function setRadio(name, value) {
      var el = form.querySelector(
        'input[name="' + name + '"][value="' + value + '"]'
      );
      if (el) el.checked = true;
    }

    var s = load();
    setRadio("theme", s.theme || "system");
    setRadio("fontSize", s.fontSize || "default");
    setRadio("motion", s.motion || "system");

    form.addEventListener("change", function (e) {
      var t = e.target;
      if (!t || t.type !== "radio") return;
      var current = load();
      current[t.name] = t.value;
      save(current);
      applyToDOM(current);
    });
  })();
</script>

<style>
  .settings-form {
    margin-top: 1.5rem;
  }

  .settings-form fieldset {
    border: 0;
    padding: 0;
    margin: 0 0 2rem 0;
  }

  .settings-form legend {
    font-family: theme("fontFamily.serif");
    font-weight: 600;
    font-size: 1rem;
    color: var(--c-ink);
    margin-bottom: 0.5rem;
    padding: 0;
  }

  .settings-form label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.375rem 0;
    cursor: pointer;
    font-size: 1rem;
    color: var(--c-ink);
  }

  /* Custom radios styled as small paper-tone pills with a gold dot
     when selected. Matches the calm document palette. */
  .settings-form input[type="radio"] {
    appearance: none;
    -webkit-appearance: none;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--c-rule-rgb), 0.5);
    background-color: var(--c-paper);
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    margin: 0;
  }

  .settings-form input[type="radio"]:checked {
    border-color: var(--c-gold);
    background-color: var(--c-gold);
    box-shadow: inset 0 0 0 3px var(--c-paper);
  }

  /* Focus uses the global :focus-visible rule from global.css —
     an ink-colored ring at 3px offset, contrast-safe in both
     themes. Don't override with gold here; gold falls below 3:1
     against ivory paper (see docs/contrast-audit-2026-05-11.md). */
</style>
