---
import BaseLayout from "../layouts/BaseLayout.astro";

// Contact — email link only. A real form (Calendly / Formspree /
// serverless) can land when there's a backend.
---

<BaseLayout
  title="Contact"
  description="Book a Discovery Call with Stacey. Short, free, unhurried, and no pressure to continue."
>
  <section class="section" aria-labelledby="contact-heading">
    <div class="column">
      <h1 id="contact-heading">Book a Discovery Call</h1>

      <p>
        Send Stacey a note. She reads every message herself, usually
        within a day or two, and she'll write back &mdash; even just
        to say she isn't the right fit. There are no autoresponders
        on the other end of this email.
      </p>

      <p>
        A Discovery Call is free and takes twenty to thirty minutes
        over Zoom, with no obligation to keep going afterward. A short
        note is fine; so is a long one.
      </p>

      <p class="contact-email">
        <a href="mailto:stacey@theyellowlegalpad.co?subject=Discovery%20Call">
          stacey@theyellowlegalpad.co
        </a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="column">
      <p class="contact-step-heading">After you write</p>
      <p>
        Stacey reads your note herself, usually within a day or two.
        If it seems like the right kind of fit, she'll send a link
        to book a free Discovery Call &mdash; twenty to thirty minutes
        on Zoom. She'll listen, ask a few questions, and tell you
        honestly whether she can help. There's no obligation to
        continue afterward.
      </p>

      <p>
        You don't need to summarize your whole financial picture or
        know exactly what you want. "I've been meaning to talk to
        someone about money" is enough.
      </p>

      <p>
        And if you write and never end up booking a session, that
        is also fine. Stacey isn't tracking conversion rates.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-email {
    margin-top: 1.5rem;
    font-size: 1.25rem;
  }
  /* Section step heading — a small quiet label that frames the
     'what happens next' paragraph without becoming a procedural
     h2. Sits at the typographic register of an italic dek rather
     than a numbered step. */
  .contact-step-heading {
    font-style: italic;
    color: var(--c-ink-soft);
    margin-bottom: 0.375rem;
  }
</style>
