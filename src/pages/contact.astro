---
import BaseLayout from "../layouts/BaseLayout.astro";

// Contact — email link only. A real form (Calendly / Formspree /
// serverless) can land when there's a backend.
---

<BaseLayout
  title="Contact"
  description="Book a Discovery Call with Stacey. Short, free, unhurried, and no pressure to continue."
>
  <section class="section" aria-labelledby="contact-heading">
    <div class="column">
      <h1 id="contact-heading">Book a Discovery Call</h1>

      <p>
        Send Stacey a note. She reads every message herself, usually
        within a day or two, and she'll write back &mdash; even just
        to say she isn't the right fit. There are no autoresponders
        on the other end of this email.
      </p>

      <p>
        A Discovery Call is free and takes about twenty minutes, with
        no obligation to keep going afterward. A short note is fine;
        so is a long one.
      </p>

      <p class="contact-email">
        <a href="mailto:hello@yellowlegalpad.example?subject=Discovery%20Call">
          hello@yellowlegalpad.example
        </a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="column">
      <p>
        You don't need to summarize your whole financial picture or
        know exactly what you want. "I've been meaning to talk to
        someone about money" is enough.
      </p>

      <p>
        And if you write and never end up booking a session, that
        is also fine. Stacey isn't tracking conversion rates.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-email {
    margin-top: 1.5rem;
    font-size: 1.25rem;
  }
</style>
